/*--------------------------------*- C++ -*----------------------------------*\
| OpenFOAM 13 (Foundation) -- controlDict                                     |
| 実行は foamRun。solver で incompressibleFluid モジュールを読む(v11+)。        |
\*---------------------------------------------------------------------------*/
FoamFile { format ascii; class dictionary; object controlDict; }
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solver          incompressibleFluid;   // ← v13 のキモ (simpleFoam等は使わない)

// --- 定常 RANS 既定。LES に切替時は deltaT/endTime/adjustTimeStep/maxCo を変更 ---
startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         2000;          // 定常: 反復回数。LES: 物理時間[s]に変更
deltaT          1;             // 定常: 1。LES: CFLから小さく
writeControl    timeStep;      // LES: adjustableRunTime
writeInterval   200;
purgeWrite      3;
writeFormat     binary;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;
runTimeModifiable yes;

adjustTimeStep  no;            // LES: yes
maxCo           1;             // LES のみ有効

functions
{
    #includeFunc forceCoeffs
    #includeFunc surfaces
    // LES/音響時に有効化:
    // #includeFunc probes
    // #includeFunc fieldAverage
}
// ************************************************************************* //
