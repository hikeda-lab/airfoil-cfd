/*--- OpenFOAM 13 fvSolution : 定常SIMPLE 既定。LES は PIMPLE(nCorrectors) に ---*/
FoamFile { format ascii; class dictionary; object fvSolution; }

solvers
{
    p { solver GAMG; smoother GaussSeidel; tolerance 1e-7; relTol 0.01; }
    "(U|k|omega|nut)"
    { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-8; relTol 0.05; }
}

SIMPLE
{
    nNonOrthogonalCorrectors 6;    // 3→6: 非直交 86° への対処
    consistent      yes;
    residualControl { p 1e-4; U 1e-4; "(k|omega)" 1e-4; }
}

// LES 用(切替時に使用):
PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors      2;
    nNonOrthogonalCorrectors 1;
}

relaxationFactors
{
    fields    { p 0.3; }
    equations { U 0.7; "(k|omega)" 0.7; }
}
// ************************************************************************* //
